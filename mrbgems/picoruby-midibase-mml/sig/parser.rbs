module MIDIBASE
  module MML
    class Parser
      NOTES: Hash[Integer, Integer]
      DOT_NUMERATORS: Array[Integer]
      DOT_DENOMINATORS: Array[Integer]
      @source: String
      @channel: Integer
      @ppqn: Integer
      @loop: bool
      @raise_error: bool
      @cursor: Integer
      @octave: Integer
      @tempo: Integer
      @gate: Integer
      @transpose: Integer
      @default_length: Integer
      @pending_ticks: Integer
      @queue: Array[timed_event_t]
      @queue_index: Integer
      @finished: bool
      @segno_pos: Integer?
      @bar: Integer
      def initialize: (String track, channel: Integer, ?ppqn: Integer, ?loop: bool, ?exception: bool) -> void
      def reset: () -> self
      def next_event: () -> timed_event_t?
      private def enqueue_rpn: () -> void
      private def push: (event_t event, ?Integer? delta) -> void
      private def shift_event: () -> timed_event_t?
      private def read_note: (Integer letter, Integer? accidental) -> Integer
      private def read_length: () -> Integer
      private def length_ticks: (Integer fraction, Integer dots) -> Integer
      private def length_ticks_from_base: (Integer base, Integer dots) -> Integer
      private def count_dots: () -> Integer
      private def read_number_after_cursor: () -> Integer?
      private def read_transpose: () -> void
      private def scale_15_to_127: (Integer value) -> Integer
      private def clamp: (Integer value, Integer min, Integer max) -> Integer
      private def invalid_character: (Integer c) -> void
      private def expand_loops: (String source) -> String
      private def expand: (String source, Integer index, Integer depth) -> [String, Integer]
    end
  end
end
