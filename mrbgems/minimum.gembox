MRuby::GemBox.new do |conf|
  conf.gem core: 'mruby-compiler-prism'
  if posix?
    conf.gem gemdir: "#{MRUBY_ROOT}/mrbgems/picoruby-mruby/lib/mruby/mrbgems/mruby-bin-mrbc-prism"
    conf.gem core: 'picoruby-bin-picoruby'
  end
  if vm_mrubyc?
    conf.gem core: 'picoruby-mrubyc'
  elsif vm_mruby?
    conf.gem core: 'picoruby-mruby'
  end
end
