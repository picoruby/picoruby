module MIDIBASE
  type event_value_t = untyped
  type event_t = Array[event_value_t]
  type context_value_t = untyped
  type midi_write_result_t = untyped

  DEFAULT_SOURCE: Router::source_t
  NOTE_OFF: Integer
  NOTE_ON: Integer
  POLYPHONIC_KEY_PRESSURE: Integer
  CONTROL_CHANGE: Integer
  PROGRAM_CHANGE: Integer
  CHANNEL_PRESSURE: Integer
  PITCH_BEND: Integer
  SYSTEM_EXCLUSIVE: Integer
  TIME_CODE_QUARTER_FRAME: Integer
  SONG_POSITION: Integer
  SONG_SELECT: Integer
  TUNE_REQUEST: Integer
  END_OF_EXCLUSIVE: Integer
  TIMING_CLOCK: Integer
  START: Integer
  CONTINUE: Integer
  STOP: Integer
  ACTIVE_SENSING: Integer
  SYSTEM_RESET: Integer
  DEFAULT_MAX_SYSEX_BYTES: Integer
  CHANNEL_EVENTS: Array[Symbol]
  TRANSPORT_EVENTS: Array[Symbol]
  WIRE_EVENTS: Array[Symbol]

  def self.encode: (Symbol command, *(Integer | String) values) -> Array[Integer]
  def self.channel_event: (Integer status, Array[Integer | String] values, Integer count) -> Array[Integer]
  def self.single_value: (Array[Integer | String] values) -> (Integer | String)
  def self.no_value_event: (Array[Integer | String] values, Integer status) -> Array[Integer]
  def self.require_values: (Array[Integer | String] values, Integer count) -> void
  def self.channel_value: (Integer | String value) -> Integer
  def self.data_value: (Integer | String value) -> Integer
  def self.fourteen_bit_value: (Integer | String value) -> Integer

  @midi_parser: Parser?
  @midi_clock: Clock?
  @last_event_timestamp_us: Integer?
  def initialize_midibase: (?time_signature: Array[Integer], ?max_sysex_bytes: Integer) -> self
  attr_reader last_event_timestamp_us: Integer?
  def getevent: () -> event_t
  def putevent: (Symbol command, *(Integer | String) values) -> Integer
  def handle: (event_t event, **context_value_t context) -> Integer
  def handle_midi: (event_t event, Router::source_t source, Integer priority, Integer timestamp_us) -> Integer
  def bpm: () -> Float?
  def clock_running?: () -> boolish
  def time_signature: () -> Array[Integer]?
  def time_signature=: (Array[Integer] signature) -> Array[Integer]
  def position: () -> Array[Integer]
  def bar: () -> Integer
  def beat: () -> Integer
  def tick: () -> Integer
  private def midi_read_byte: () -> Integer?
  private def midi_read_timestamp_us: () -> Integer
  private def midi_write_byte: (Integer byte) -> midi_write_result_t
end
