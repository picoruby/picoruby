module PSG
  class MIDIController
    CC_TIMBRE: Integer
    CC_ENV_PERIOD: Integer
    CC_ENV_SHAPE: Integer
    CC_ENV_ENABLED: Integer
    CC_LFO_RATE: Integer
    CC_MIXER: Integer
    CC_NOISE_PERIOD: Integer
    CC_BEND_RANGE: Integer
    TIMBRE_NAMES: Array[String]
    MIXER_NAMES: Array[String]

    @synth: untyped
    @logger: untyped
    @last_reported: Hash[Array[untyped], untyped]

    def initialize: (untyped synth, ?logger: untyped) -> void
    def handle: (MIDIBASE::event_t event, ?source: untyped, ?priority: Integer, ?timestamp_us: Integer?, **untyped context) -> bool
    private def map_event: (MIDIBASE::event_t event) -> Array[untyped]
    private def map_control_change: (MIDIBASE::event_t event) -> Array[untyped]
    private def standard_control_report: (Integer controller, Integer value) -> Array[untyped]?
    private def envelope_period: (Integer value) -> Integer
    private def report_change: (untyped source, MIDIBASE::event_t original_event, Array[untyped] report) -> void
    private def clamp: (Integer value, Integer min, Integer max) -> Integer
  end
end
