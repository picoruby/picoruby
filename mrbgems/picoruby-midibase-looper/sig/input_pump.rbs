module MIDIBASE
  class Looper
    class InputPump
      DEFAULT_PRIORITY: Integer

      @input: untyped
      @output: untyped
      @source: untyped
      @stopped: bool
      @task: Task?
      @priority: Integer
      @timestamped_input: bool
      @fast_output: bool

      def initialize: (untyped input, output: untyped, source: untyped, ?priority: Integer) -> void
      def start: () -> self
      def run: () -> void
      def stop: () -> self
      def join: () -> self
    end
  end
end
