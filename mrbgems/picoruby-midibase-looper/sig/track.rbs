module MIDIBASE
  class Looper
    class Track
      @events: EventBuffer
      @source: Symbol
      @voice_limit: Integer
      @channel_mask: Integer
      @muted: bool
      @cursor: Integer
      @cycle: Integer
      @current_event: MIDIBASE::event_t?
      @active: Array[Integer]
      attr_reader events: EventBuffer
      attr_reader source: Symbol
      attr_reader voice_limit: Integer
      attr_reader channel_mask: Integer
      attr_accessor muted: bool
      def initialize: (EventBuffer events, source: Symbol, voice_limit: Integer, ?channel_mask: Integer) -> void
      def copy: () -> Track
      def reset: () -> self
      def next_tick: (Integer loop_ticks) -> Integer?
      def current_event: () -> MIDIBASE::event_t
      def advance: (Integer loop_ticks) -> Integer
      def seek: (Integer absolute_tick, Integer loop_ticks) -> self
      def note_started: (MIDIBASE::event_t event) -> Array[Integer]
      def note_stopped: (MIDIBASE::event_t event) -> void
      def take_active_notes: () -> Array[Integer]
    end
  end
end
